---
import type { ImageMetadata } from "astro";

interface Props {
  year: string;
  image: string | ImageMetadata;
  description: string[];
  title?: string;
}

const { year, image, description, title } = Astro.props;
---

<div
  class="fade-item grid grid-cols-[90px_36px_120px_1fr] items-center gap-x-4 md:grid-cols-[100px_40px_140px_1fr] md:gap-x-6"
>
  <!-- 年 -->
  <p class="text-right text-[40px] font-semibold text-cherry">
    {year}
  </p>

  <!-- 横線と丸 -->
  <div class="relative h-full min-h-[140px]">
    <div
      class="absolute top-1/2 left-0 h-[5px] w-[55px] -translate-y-1/2 bg-cherry"
    ></div>

    <div
      class="absolute top-1/2 left-0 z-10 size-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary"
    ></div>
  </div>

  <!-- 写真 -->
  <div
    class="relative z-10 size-[257px] overflow-hidden rounded-full bg-[#d9d9d9] md:size-[140px]"
  >
    <img
      src={typeof image === 'string' ? image : image.src}
      alt=""
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>

  <!-- 説明 -->
  <div class="space-y-2 text-[24px] leading-7s">
    {
      description.map((text) => (
        <p>{text}</p>
      ))
    }
  </div>
</div>