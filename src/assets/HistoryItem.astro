---
import type { ImageMetadata } from "astro";

interface Props {
  year: string;
  image: string | ImageMetadata;
  description: string[];
  title?: string;
}

const { year, image, description, title } = Astro.props;
---

<div
  class="fade-item grid min-h-0 grid-cols-1 items-center gap-5 py-6 md:min-h-[260px] md:grid-cols-[180px_80px_257px_1fr] md:gap-0 md:py-0"
>
  <p
    class="text-center text-[32px] font-semibold text-cherry sm:text-[36px] md:text-left md:text-[40px]"
  >
    {year}
  </p>

  <div class="relative hidden h-full min-h-[140px] md:block">
    <div
      class="absolute left-6 top-1/2 h-[15px] w-[78px] -translate-y-1/2 bg-cherry"
    ></div>
  </div>


  <div
    class="relative z-10 mx-auto h-[190px] w-[190px] shrink-0 overflow-hidden rounded-full bg-[#d9d9d9] sm:h-[220px] sm:w-[220px] md:ml-4 md:mr-0 md:h-[257px] md:w-[257px]"
  >
    <img
      src={typeof image === "string" ? image : image.src}
      alt={title ?? `${year}年の写真`}
      class="h-full w-full object-cover"
      loading="lazy"
    />
  </div>

  <div
    class="space-y-2 text-center text-[16px] leading-[28px] text-text sm:text-[18px] sm:leading-[30px] md:pl-10 md:text-left md:text-[24px] md:leading-normal"
  >
    {
      title && (
        <h3 class="mb-3 text-[20px] font-semibold sm:text-[22px] md:text-[24px]">
          {title}
        </h3>
      )
    }

    {
      description.map((text) => (
        <p>{text}</p>
      ))
    }
  </div>
</div>