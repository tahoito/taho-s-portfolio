---
import type { ImageMetadata } from "astro";

interface Props {
  year: string;
  image: string | ImageMetadata;
  description: string[];
  title?: string;
}

const {
  year,
  image,
  description,
  title,
} = Astro.props;

const imageSrc =
  typeof image === "string" ? image : image.src;
---

<div
  class="grid min-h-0 grid-cols-[35px_1fr] items-start md:min-h-[260px] md:grid-cols-[180px_80px_257px_1fr] md:items-center"
>
  <!-- スマホ用の丸 -->
  <div class="relative flex justify-center pt-2 md:hidden">
    <div
      class="relative z-20 h-[14px] w-[14px] rounded-full bg-cherry ring-4 ring-bg1"
    ></div>
  </div>

  <!-- スマホ用コンテンツ -->
  <div class="min-w-0 pl-4 md:contents">
    <!-- 年 -->
    <p
      class="text-[28px] font-semibold leading-none text-cherry sm:text-[32px] md:text-left md:text-[40px]"
    >
      {year}
    </p>

    <!-- PC用の横線 -->
    <div
      class="relative hidden h-full min-h-[140px] md:block"
    >
      <div
        class="absolute left-6 top-1/2 h-[15px] w-[78px] -translate-y-1/2 bg-cherry"
      ></div>
    </div>

    <!-- 写真 -->
    <div
      class="mt-5 h-[190px] w-[190px] overflow-hidden rounded-full bg-[#d9d9d9] sm:h-[220px] sm:w-[220px] md:mx-0 md:mt-0 md:h-[257px] md:w-[257px]"
    >
      <img
        src={imageSrc}
        alt={title ?? year}
        class="h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    <!-- テキスト -->
    <div
      class="mt-6 min-w-0 pb-3 text-text md:mt-0 md:pl-10"
    >
      {
        title && (
          <h3
            class="break-words text-[19px] font-semibold leading-8 sm:text-[21px] md:text-[22px]"
          >
            {title}
          </h3>
        )
      }

      <div
        class:list={[
          "space-y-2 text-[15px] leading-7 sm:text-[16px] md:text-[18px] md:leading-8",
          title ? "mt-2" : "",
        ]}
      >
        {
          description.map((text) => (
            <p class="break-words">{text}</p>
          ))
        }
      </div>
    </div>
  </div>
</div>