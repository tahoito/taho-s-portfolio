---
import { getHistories } from "../data/history";
import HistoryItem from "../assets/HistoryItem.astro";

interface Props {
  t: {
    history: {
      title: string;

      title_2008: string;
      description_2008: string[];

      title_2018: string;
      description_2018: string[];

      title_2023: string;
      description_2023: string[];

      title_2025: string;
      description_2025: string[];

      title_2026: string;
      description_2026: string[];
    };
  };

  lang: "ja" | "en";
}

const { t } = Astro.props;

const histories = getHistories(t.history);
---

<section
  id="history"
  class="flex min-h-screen flex-col items-center bg-bg1 px-5 py-20 sm:px-8 md:py-24"
>
  <div class="history-heading text-center">
    <h2
      class="font-title text-[42px] font-medium text-text-title sm:text-[48px] md:text-[56px]"
    >
      History...
    </h2>

    <p
      class="mx-auto mt-4 max-w-[700px] text-[15px] leading-7 text-text sm:text-[16px] md:text-[18px]"
    >
      {t.history.title}
    </p>
  </div>

  <div class="relative mt-14 w-full max-w-6xl md:mt-20">
    <!-- スマホ用の縦棒背景 -->
    <div
      class="absolute left-[15px] top-5 h-[calc(100%-40px)] w-[5px] rounded-full bg-cherry/20 md:hidden"
    ></div>

    <!-- スマホ用の伸びる縦棒 -->
    <div
      class="history-line-mobile absolute left-[15px] top-5 h-[calc(100%-40px)] w-[5px] origin-top rounded-full bg-cherry md:hidden"
    ></div>

    <!-- PC用の縦棒背景 -->
    <div
      class="absolute left-[200px] top-[40px] hidden h-[calc(100%-80px)] w-[15px] bg-cherry/20 md:block"
    ></div>

    <!-- PC用の伸びる縦棒 -->
    <div
      class="history-line-desktop absolute left-[200px] top-[40px] hidden h-[calc(100%-80px)] w-[15px] origin-top bg-cherry md:block"
    ></div>

    <div class="relative z-10 flex flex-col gap-14 md:gap-10">
      {
        histories.map((history, index) => (
          <div
            class="history-item"
            style={`--history-delay: ${index * 100}ms`}
          >
            <HistoryItem
              year={history.year}
              title={history.title}
              description={history.description}
              image={history.image}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .history-heading {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }

  .history-heading.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .history-item {
    opacity: 0;
    transform: translateY(45px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
    transition-delay: var(--history-delay);
  }

  .history-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .history-line-mobile,
  .history-line-desktop {
    transform: scaleY(0);
    transition: transform 2.8s ease-out;
  }

  .history-line-mobile.is-visible,
  .history-line-desktop.is-visible {
    transform: scaleY(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .history-heading,
    .history-item {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .history-line-mobile,
    .history-line-desktop {
      transform: scaleY(1);
      transition: none;
    }
  }
</style>

<script is:inline>
  function setupHistoryAnimation() {
    const historySection = document.querySelector("#history");

    if (!historySection) {
      return;
    }

    const historyHeading =
      historySection.querySelector(".history-heading");

    const historyItems =
      historySection.querySelectorAll(".history-item");

    const historyLines =
      historySection.querySelectorAll(
        ".history-line-mobile, .history-line-desktop"
      );

    const sectionObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }

          historyHeading?.classList.add("is-visible");

          historyLines.forEach((line) => {
            line.classList.add("is-visible");
          });

          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.1,
      }
    );

    sectionObserver.observe(historySection);

    const itemObserver = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }

          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.15,
        rootMargin: "0px 0px -50px 0px",
      }
    );

    historyItems.forEach((item) => {
      itemObserver.observe(item);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      setupHistoryAnimation
    );
  } else {
    setupHistoryAnimation();
  }

  document.addEventListener(
    "astro:page-load",
    setupHistoryAnimation
  );
</script>