---
import { histories } from "../data/history";
import HistoryItem from "./HistoryItem.astro";
---

<section class="overflow-hidden px-5 py-16 sm:px-8 sm:py-20 lg:px-12 lg:py-24">
  <div class="relative mx-auto w-full max-w-7xl">
    <div
      class="absolute bottom-0 left-[8px] top-0 w-[4px] rounded-full bg-primary md:hidden"
    ></div>

    <div
      class="absolute bottom-0 left-[180px] top-0 hidden w-[6px] rounded-full bg-primary md:block"
    ></div>

    <div class="space-y-10 pl-7 sm:space-y-14 md:space-y-0 md:pl-0">
      {
        histories.map((history) => (
          <HistoryItem {...history} />
        ))
      }
    </div>
  </div>
</section>