---
import type { ImageMetadata } from "astro";
import { X } from "lucide-astro";

interface Props {
  name: string;
  image: ImageMetadata;
}

const { name, image } = Astro.props;
const id = name.replace(/\s+/g, "-").toLowerCase();
---

<div
  class="group mx-auto w-fit cursor-pointer"
  onclick={`document.getElementById('${id}')?.showModal()`}
>
  <div class="h-[193px] w-[332px] overflow-hidden bg-cherry shadow-md transition duration-300 group-hover:-translate-y-2 group-hover:shadow-xl">
    <img
      src={image.src}
      alt={name}
      class="h-full w-full object-cover transition duration-300 group-hover:scale-110"
    />
  </div>

  <p class="mt-2 text-center text-[18px] font-medium text-text">
    {name}
  </p>
</div>

<dialog
  id={id}
  class="backdrop:bg-black/70"
>
  <div class="relative w-[900px] bg-bg1">

    <button
      class="absolute right-5 top-5 flex justify-center items-center h-12 w-12 rounded-full bg-cherry text-white transition hover:scale-110 outline-none focus:outline-none focus:ring-0"
      onclick={`document.getElementById('${id}')?.close()`}
    >
      <X class="h-10 w-10" />
    </button>


    <div>
      <h2 class="text-[24px] font-medium text-text">
        {name}
      </h2>

      <div class="grid grid-cols-2 gap-8 p-8">
        <div>
          <img
            src={image.src}
            alt={name}
          />

          <div class="mt-3 flex flex-wrap gap-2">
              <span class="rounded bg-cherry px-3 py-1 text-white">
                Astro
              </span>
              <span class="rounded bg-cherry px-3 py-1 text-white">
                Tailwind
              </span>
              <span class="rounded bg-cherry px-3 py-1 text-white">
                TypeScript
              </span>
            </div>
        </div>

        <div>
          <h3 class="text-[18px] font-medium text-text">
            アプリ概要
          </h3>
          <p class="mt-4 text-text">
            ここに作品の説明を書きます。
          </p>
          <div class="mt-8">
            <h3 class="text-[18px] font-medium text-text">
              開発期間
            </h3>
            <p class="mt-4 text-text">
              ここに作品の説明を書きます。
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</dialog>