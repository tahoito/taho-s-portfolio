---
import type { ImageMetadata } from "astro";
import { X } from "lucide-astro";

interface Props {
  name: string;
  image: ImageMetadata;
  description?: string;
  period: string;
  techs: string[];
  githubUrl?: string;
}

const {
  name,
  image,
  description,
  period,
  techs,
  githubUrl,
} = Astro.props;

const id = name.replace(/\s+/g, "-").toLowerCase();
---

<div
  class="fade-item group mx-auto w-fit cursor-pointer"
  onclick={`document.getElementById('${id}')?.showModal()`}
>
  <div class="h-[193px] w-[332px] overflow-hidden bg-cherry shadow-md transition duration-300 group-hover:-translate-y-2 group-hover:shadow-xl">
    <img
      src={image.src}
      alt={name}
      class="h-full w-full object-cover transition duration-300 group-hover:scale-110"
    />
  </div>

  <p class="mt-2 text-center text-[18px] font-medium text-text">
    {name}
  </p>
</div>

<dialog
  id={id}
  class="m-0 h-screen w-screen max-w-none bg-transparent p-0 backdrop:bg-black/70"
>
  <div class="flex min-h-screen items-center justify-center px-8 py-10">

    <div class="relative w-full max-w-6xl bg-bg1 px-16 py-12">
      <button
        class="absolute right-8 top-8 flex h-14 w-14 items-center justify-center rounded-full bg-cherry text-white transition duration-300 focus:outline-none focus:ring-0 hover:scale-110"
        onclick={`document.getElementById('${id}')?.close()`}
      >
        <X class="h-9 w-9 stroke-[2]" />
      </button>

      <h2 class="text-[40px] font-semibold text-text">
        {name}
      </h2>

      <div class="mt-12 flex gap-16">

        <div class="w-[440px] shrink-0">

          <img
            src={image.src}
            alt={name}
            class="w-full border border-gray-200"
          />

          <div class="mt-10">
            <h3 class="text-[18px] font-medium text-text">
              使用技術
            </h3>

            <div class="mt-5 flex flex-wrap gap-3">
              {techs.map((tech) => (
                <span class="rounded-md bg-cherry px-3 py-1 text-white">
                  {tech}
                </span>
              ))}
            </div>
          </div>

        </div>

        <div class="flex-1 flex flex-col gap-6">
          <section>
            <h3 class="text-[18px] font-medium text-text">
              アプリ概要
            </h3>

            <p class="whitespace-pre-line text-[16px] leading-[23px] text-text">
              {description}
            </p>
          </section>

          <section class="mt-4">
            <h3 class="text-[18px] font-medium text-text">
              開発期間
            </h3>

            <p class="mt-2 text-[16px] text-text">
              {period}
            </p>
            </section>

            {githubUrl && (
              <section>
                <h3 class="text-[18px] font-medium text-text">
                  GitHub
                </h3>

                <a
                  href={githubUrl}
                  target="_blank"
                  class="mt-2 inline-block text-[16px] text-cherry hover:underline"
                >
                  {githubUrl}
                </a>
              </section>
            )}

        </div>
      </div>
    </div>
  </div>
</dialog>


<style>
.fade-item {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.6s ease;
}

.fade-item.show {
  opacity: 1;
  transform: translateY(0);
}
</style>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add("show");
    }
  });
});

document.querySelectorAll(".fade-item").forEach((el) => observer.observe(el));
</script>
