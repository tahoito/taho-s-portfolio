---
import type { ImageMetadata } from "astro";
import { X } from "lucide-astro";

interface Props {
  t: {
    works: {
      title: string,
      content: string,
      stuck: string,
      period: string,
  },
  };

  lang: "ja" | "en";
}

const { t, lang } = Astro.props;



interface Props {
  name: string;
  image: ImageMetadata | ImageMetadata[];
  description?: string;
  period: string;
  techs: string[];
  githubUrl?: string;
}

const {
  name,
  image,
  description,
  period,
  techs,
  githubUrl,
} = Astro.props;

const images = Array.isArray(image) ? image : [image];
const id = name.replace(/\s+/g, "-").toLowerCase();
---

<div
  class="fade-item group w-full cursor-pointer transition duration-300 md:hover:scale-[1.05]"
  onclick={`document.getElementById('${id}')?.showModal()`}
>
  <div
    class="aspect-[332/193] w-full overflow-hidden bg-cherry shadow-md transition duration-300 group-hover:shadow-xl"
  >
    <img
      src={images[0].src}
      alt={name}
      class="h-full w-full object-cover transition duration-300"
    />
  </div>

  <p class="mt-2 text-center text-[16px] font-medium text-text sm:text-[18px]">
    {name}
  </p>
</div>


<dialog
  id={id}
  class="work-card-modal m-0 h-screen w-screen max-w-none bg-transparent p-0 backdrop:bg-black/70"
>
  <div class="flex min-h-screen items-center justify-center px-6 py-8">
    <div
      class="modal-content relative max-h-[90vh] w-full max-w-[1100px] overflow-y-auto rounded-md bg-bg1 px-10 py-10 lg:px-14 lg:py-12"
    >
      <button
        class="absolute right-6 top-6 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-cherry text-white transition duration-300 hover:scale-110 focus:outline-none focus:ring-0"
        data-close-dialog
        type="button"
        aria-label="Close modal"
      >
        <X class="h-6 w-6 stroke-[2]" />
      </button>

      <h2 class="pr-16 text-[32px] font-semibold text-text lg:text-[40px]">
        {name}
      </h2>

      <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-[420px_1fr] lg:gap-14">

        <!-- 左側 -->
        <div>
          <div
            class="flex aspect-[4/3] w-full items-center justify-center overflow-hidden rounded-md border border-gray-200 bg-white"
          >
            <img
              src={images[0].src}
              alt={name}
              id={`${id}-image`}
              class="max-h-full max-w-full object-contain transition-all duration-300"
            />
          </div>

          {images.length > 1 && (
            <div class="mt-4 flex justify-center gap-2">
              {images.map((img, index: number) => (
                <button
                  class:list={[
                    "dot h-3 w-3 rounded-full transition",
                    index === 0 ? "bg-cherry" : "bg-gray-300",
                  ]}
                  data-index={index}
                  data-src={img.src}
                  data-id={id}
                  type="button"
                  aria-label={`Show image ${index + 1}`}
                />
              ))}
            </div>
          )}

          <section class="mt-8">
            <h3 class="text-[18px] font-medium text-text">
              {t.works.stuck}
            </h3>

            <div class="mt-4 flex flex-wrap gap-2">
              {techs.map((tech) => (
                <span class="rounded-md bg-cherry px-3 py-1 text-[14px] text-white">
                  {tech}
                </span>
              ))}
            </div>
          </section>
        </div>

        <!-- 右側 -->
        <div class="flex flex-col gap-8">
          <section>
            <h3 class="text-[18px] font-medium text-text">
              {t.works.content}
            </h3>

            <p class="mt-3 whitespace-pre-line text-[16px] leading-7 text-text">
              {description}
            </p>
          </section>

          <section>
            <h3 class="text-[18px] font-medium text-text">
              {t.works.period}
            </h3>

            <p class="mt-3 text-[16px] text-text">
              {period}
            </p>
          </section>

          {githubUrl && (
            <section>
              <h3 class="text-[18px] font-medium text-text">
                GitHub
              </h3>

              <a
                href={githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-block break-all text-[16px] text-cherry hover:underline"
              >
                {githubUrl}
              </a>
            </section>
          )}
        </div>

      </div>
    </div>
  </div>
</dialog>


<style>
.fade-item {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.6s ease;
}

.fade-item.show {
  opacity: 1;
  transform: translateY(0);
}

/* モーダルの中身 */
.work-card-modal[open] .modal-content {
  animation: modal-pop 0.3s ease-out forwards;
}

.work-card-modal.closing .modal-content {
  animation: modal-pop-out 0.2s ease-in forwards;
}

/* 背景 */
.work-card-modal[open]::backdrop {
  animation: backdrop-fade 0.25s ease-out;
}

.work-card-modal.closing::backdrop {
  animation: backdrop-fade-out 0.2s ease-in forwards;
}

@keyframes modal-pop {
  0% {
    opacity: 0;
    transform: scale(0.9);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes modal-pop-out {
  0% {
    opacity: 1;
    transform: scale(1);
  }

  100% {
    opacity: 0;
    transform: scale(0.95);
  }
}

@keyframes backdrop-fade {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes backdrop-fade-out {
  from {
    opacity: 1;
  }

  to {
    opacity: 0;
  }
}
</style>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add("show");
    }
  });
});

document.querySelectorAll(".fade-item").forEach((el) => observer.observe(el));

document.querySelectorAll<HTMLDialogElement>(".work-card-modal").forEach((dialog) => {
  const image = dialog.querySelector<HTMLImageElement>("img[id$='-image']");
  const buttons = Array.from(dialog.querySelectorAll<HTMLButtonElement>(".dot"));
  let currentIndex = 0;

  if (!image) return;

  const updateImage = (index: number) => {
    if (buttons.length === 0) return;
    const normalized = ((index % buttons.length) + buttons.length) % buttons.length;
    const button = buttons[normalized];
    const src = button.dataset.src;
    if (!src) return;

    currentIndex = normalized;
    image.src = src;
    buttons.forEach((btn, idx) => {
      btn.classList.toggle("bg-cherry", idx === currentIndex);
      btn.classList.toggle("bg-gray-300", idx !== currentIndex);
    });
  };

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const index = Number(button.dataset.index ?? 0);
      updateImage(index);
    });
  });

  const closeButton = dialog.querySelector<HTMLButtonElement>("[data-close-dialog]");

  closeButton?.addEventListener("click", (event) => {
    event.preventDefault();
    dialog.classList.add("closing");

    const handleAnimationEnd = (event: Event) => {
      const animationEvent = event as AnimationEvent;
      if (animationEvent.animationName !== "modal-pop-out") return;
      dialog.removeEventListener("animationend", handleAnimationEnd);
      dialog.close();
      dialog.classList.remove("closing");
    };

    dialog.addEventListener("animationend", handleAnimationEnd as EventListener);
  });
});
</script>
