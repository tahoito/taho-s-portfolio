---
import { Mail } from "lucide-astro";
import github from "../assets/icons/github.svg";
import insta from "../assets/icons/insta.svg";
import LinkedIn from "../assets/icons/LinkedIn.svg";

interface Props {
  t: {
    contact: {
      message1: string;
      message2: string;
    };
  };

  lang: "ja" | "en";
}

const { t, lang } = Astro.props;
---

<section
  id="contact"
  class="flex min-h-screen items-center justify-center bg-bg2 px-6 py-20 sm:py-24"
>
  <div class="mx-auto w-full max-w-[1080px]">

    <div class="text-center text-text">
      <h1
        class="font-title text-[36px] font-medium sm:text-[46px] md:text-[56px]"
      >
        Contact
      </h1>

      <p
        class="mt-4 text-[15px] leading-7 sm:text-[16px] sm:leading-8 md:text-[18px]"
      >
        {t.contact.message1}<br />
        {t.contact.message2}
      </p>
    </div>

    <div
      class="mt-12 grid grid-cols-1 place-items-center gap-6 sm:mt-16 sm:grid-cols-2 sm:gap-8 lg:mt-20 lg:grid-cols-4 lg:gap-10"
    >
      <a
        href="mailto:tahoito.dev@gmail.com"
        aria-label="Send an email to Taho"
        class="contact-card flex h-[160px] w-full max-w-[210px] flex-col items-center justify-center rounded-[12px] border-2 border-cherry transition-all duration-300 hover:scale-105 hover:bg-cherry hover:shadow-xl sm:h-[180px] lg:h-[210px]"
      >
        <Mail
          class="h-14 w-14 stroke-[2] text-black sm:h-16 sm:w-16 lg:h-20 lg:w-20"
        />

        <p class="mt-4 text-[16px] sm:text-[17px] lg:mt-5 lg:text-[18px]">
          Email
        </p>
      </a>

      <a
        href="https://github.com/tahoito"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Taho's GitHub profile"
        class="contact-card flex h-[160px] w-full max-w-[210px] flex-col items-center justify-center rounded-[12px] border-2 border-cherry transition-all duration-300 hover:scale-105 hover:bg-cherry hover:shadow-xl sm:h-[180px] lg:h-[210px]"
      >
        <img
          src={github.src}
          alt="GitHub"
          class="h-14 w-14 sm:h-16 sm:w-16 lg:h-20 lg:w-20"
        />

        <p class="mt-4 text-[16px] sm:text-[17px] lg:mt-5 lg:text-[18px]">
          GitHub
        </p>
      </a>

      <a
        href="https://www.instagram.com/_dagwi.34/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Taho's Instagram profile"
        class="contact-card flex h-[160px] w-full max-w-[210px] flex-col items-center justify-center rounded-[12px] border-2 border-cherry transition-all duration-300 hover:scale-105 hover:bg-cherry hover:shadow-xl sm:h-[180px] lg:h-[210px]"
      >
        <img
          src={insta.src}
          alt="Instagram"
          class="h-14 w-14 sm:h-16 sm:w-16 lg:h-20 lg:w-20"
        />

        <p class="mt-4 text-[16px] sm:text-[17px] lg:mt-5 lg:text-[18px]">
          Instagram
        </p>
      </a>

      <a
        href="https://www.linkedin.com/in/taho-ito-37526641b/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open Taho's LinkedIn profile"
        class="contact-card flex h-[160px] w-full max-w-[210px] flex-col items-center justify-center rounded-[12px] border-2 border-cherry transition-all duration-300 hover:scale-105 hover:bg-cherry hover:shadow-xl sm:h-[180px] lg:h-[210px]"
      >
        <img
          src={LinkedIn.src}
          alt="LinkedIn"
          class="h-14 w-14 sm:h-16 sm:w-16 lg:h-20 lg:w-20"
        />

        <p class="mt-4 text-[16px] sm:text-[17px] lg:mt-5 lg:text-[18px]">
          LinkedIn
        </p>
      </a>
    </div>

  </div>
</section>

<style>
  .contact-card {
    opacity: 0;
    transform: translateX(-30px) translateY(20px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .contact-card.show {
    opacity: 1;
    transform: translateX(0) translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const contactCards =
    document.querySelectorAll<HTMLElement>(".contact-card");

  if (contactCards.length > 0) {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const index = Array.from(contactCards).indexOf(
            entry.target as HTMLElement
          );

          window.setTimeout(() => {
            entry.target.classList.add("show");
          }, index * 140);

          obs.unobserve(entry.target);
        });
      },
      {
        threshold: 0.2,
      }
    );

    contactCards.forEach((card) => observer.observe(card));
  }
</script>