---
import { histories } from "../data/history";
import HistoryItem from "../assets/HistoryItem.astro";


interface Props {
  t?: any;
  lang?: "ja" | "en";
}

const { t, lang } = Astro.props;
const historyTitle = t?.history?.title ?? (lang === "ja" ? "これまでの軌跡" : "Let's take a look back at my journey.");
---


<section id="history" class="bg-bg1 px-6 py-24 md:py-32">
  <div class="mx-auto max-w-6xl">
    <!-- タイトル -->
    <div class="mb-20 text-center">
      <h1 class="font-title text-[56px] font-medium text-text-title">
        History
      </h1>

      <p class="mt-3 text-[20px]">
        {historyTitle}
      </p>
    </div>

    <!-- タイムライン -->
    <div class="relative w-full">
      <!-- 縦線 -->
      <div
        class="absolute top-0 bottom-0 left-[210px] hidden w-[16px] -translate-x-1/2 bg-cherry md:block"
      ></div>

      <!-- 経歴一覧 -->
      <div class="relative space-y-16 md:space-y-20">
        {
          histories.map((history) => (
            <HistoryItem {...history} />
          ))
        }
      </div>
    </div>
  </div>
</section>