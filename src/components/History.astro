---
import HistorySection from "../assets/HistorySection.astro";

interface Props {
  t: {
    history: {
      title_2008: string;
      description_2008: string[];

      title_2018: string;
      description_2018: string[];

      title_2023: string;
      description_2023: string[];

      title_2025: string;
      description_2025: string[];

      title_2026: string;
      description_2026: string[];
    };
  };

  lang: "ja" | "en";
}

const { t, lang } = Astro.props;
---

<HistorySection t={t} lang={lang} />